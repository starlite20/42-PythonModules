class Plant:
    def __init__(self, name: str, height: int, age: int):
        self.name = name
        self.height = height
        self.age = age
    
    def print_plant(self):
        print(f"{self.name}: {self.height}cm, {self.age} days old")

    def grow(self):
        self.height += 1

    def age(self):
        self.age += 1

if __name__=="__main__":
    garden = [
        Plant("Rose", 25, 30),
        Plant("Sunflower", 80, 45),
        Plant("Cactus", 15, 120)
    ]

    # 1. SNAPSHOT: Record initial state
    initial_heights = []
    for plant in garden:
        initial_heights.append(plant.height)

    # 2. TOP BUN: Print Day 1
    print("=== Day 1 ===")
    for plant in garden:
        plant.print_plant()

    # 3. THE MEAT: Simulate 6 days of growth (Day 2 to Day 7)
    # We loop 6 times because the plant is already at Day 1.
    for day in range(6):
        for plant in garden:
            plant.grow()
            plant.age()

    # 4. BOTTOM BUN: Print Day 7
    print("=== Day 7 ===")
    for plant in garden:
        plant.print_plant()

    # 5. REPORT: Compare current state vs initial state
    for i in range(len(garden)):
        growth = garden[i].height - initial_heights[i]
        print(f"{garden[i].name} Growth this week: +{growth}cm")